# Environment variables for Speaking Coach app
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is listed in .gitignore.

# Backend Configuration
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://speaking_coach:password@db:5432/speaking_coach
SQLALCHEMY_ECHO=false

# Redis
REDIS_URL=redis://redis:6379

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# External APIs
DEEPGRAM_API_KEY=your-deepgram-api-key
ANTHROPIC_API_KEY=sk-ant-...
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_AUDIO=speaking-coach-audio
S3_BUCKET_REPORTS=speaking-coach-reports

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Feature Flags
ENABLE_VOICE_CLONING=false
ENABLE_COACH_INTERACTION=false
ENABLE_HUMAN_COACHES=false
