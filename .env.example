# Environment variables for ci-wiki
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Backend — choose ONE of the two options below.
# ---------------------------------------------------------------------------

# Option A: Databricks Model Serving (default)
# Alternative to ~/.databrickscfg — set both to use env vars instead.
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi...

# Option B: Anthropic API (direct)
# Set this to bypass Databricks entirely. The model auto-defaults to
# claude-sonnet-4-5 unless you override it in config.yaml.
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Optional overrides — can also be set in config.yaml at the repo root.
# ---------------------------------------------------------------------------
# CI_WIKI_MODEL=claude-sonnet-4-5          # Anthropic model name example
# CI_WIKI_MODEL=databricks-claude-sonnet-4-6  # Databricks model name example
# CI_WIKI_MAX_TOKENS=8192
# CI_WIKI_RATE_LIMIT_RPM=50
# CI_WIKI_RATE_LIMIT_TPM=40000
